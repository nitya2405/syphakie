# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/syphakie

# ── App ───────────────────────────────────────────────────────────────────────
OUTPUT_DIR=outputs
BASE_URL=http://localhost:8000
DEFAULT_CREDITS=1000

# ── Provider API Keys ─────────────────────────────────────────────────────────
# Add the keys for the providers you want to enable.
# Providers without a key are automatically skipped by the routing engine.

# Text / Chat
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
XAI_API_KEY=xai-...
QWEN_API_KEY=...

# Image / Video / Audio (via Fal.ai — covers Kling, Luma, Hailuo, Wan, ByteDance, Runway, Topaz, BlackForestLabs)
FAL_API_KEY=...

# Image generation (Stability AI)
STABILITY_API_KEY=sk-...

# Audio / TTS (ElevenLabs)
ELEVENLABS_API_KEY=sk_...

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram.

TELEGRAM_BOT_TOKEN=          # required to enable the bot
TELEGRAM_BOT_USERNAME=       # e.g. SyphaKieBot  (no @, used to build deep-links)

# Webhook mode (production) — leave blank to use long-polling (dev)
TELEGRAM_WEBHOOK_URL=        # e.g. https://api.yourdomain.com/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=     # optional; random string to verify Telegram requests
